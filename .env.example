# Crew Studio
CREW_STUDIO_URL=http://localhost:8081

# Jira (REST backend)
JIRA_BACKEND=rest
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=
JIRA_API_TOKEN=
# For Jira Server: use a Personal Access Token instead of email+api_token
# JIRA_PERSONAL_ACCESS_TOKEN=

# Optional: webhook filter and auth
# JIRA_PROJECT_KEYS=PROJ,DEMO
# JIRA_TRIGGER_STATUS=Ready for Dev
# JIRA_WEBHOOK_SECRET=
# JIRA_EPIC_ISSUE_TYPES=Epic
# JIRA_STORY_JQL_TEMPLATE="Epic Link" = {epic_key} ORDER BY created ASC

# LLM for classifier (or use ~/.crew-ai/config.yaml)
# LLM_API_BASE_URL=
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Optional: port
# CONNECTOR_PORT=8080
